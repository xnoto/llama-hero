# llama-server.env — Environment variables injected into the container
#
# Place alongside the .container file or reference via:
#   EnvironmentFile=%h/.config/containers/systemd/llama-server.env
#
# NOTE: These variables are available INSIDE the container only.
# They CANNOT be interpolated into Exec= or other Quadlet directives.
# To parameterize Exec= arguments, edit the .container file directly
# or use a wrapper script as the entrypoint.

# Example: pass HIP_VISIBLE_DEVICES to select specific AMD GPUs inside container
# HIP_VISIBLE_DEVICES=0,1

# Example: ROCm debug logging
# AMD_LOG_LEVEL=3
